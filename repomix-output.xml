<file path="web/src/components/contact/ContactSection.astro">
---
import Button from "../ui/Button.astro";
import MapEmbed from "../ui/MapEmbed.astro";
import Schedule from "../ui/Schedule.astro";
import ContactCTAGroup from "./ContactCTAGroup.astro";
import { mailto } from "../../lib/links";
import type { ContactSectionDefinition } from "../../lib/contact-sections";

const { section } = Astro.props as { section: ContactSectionDefinition };
---

<section class="card stack contact-section" aria-labelledby={`contact-${section.id}-title`}>
  <h2 id={`contact-${section.id}-title`}>{section.title}</h2>
  {section.description && <p class="muted">{section.description}</p>}

  {section.contactTopics && section.contactTopics.length > 0 ? (
    <div class="contact-topics" role="table" aria-label="Contact topics">
      <div class="contact-topics__row contact-topics__row--head" role="row">
        <span>Topic</span>
        <span>Contact</span>
        <span>Best way to reach them</span>
      </div>
      {section.contactTopics.map((topic) => {
        const hasHref = Boolean(topic.href && topic.href.trim());
        const hasEmail = Boolean(topic.email && topic.email.trim());
        const methodHref = hasHref
          ? topic.href!
          : hasEmail
          ? mailto(topic.email!)
          : "";
        const methodLabel =
          topic.hrefLabel ?? (hasHref ? "Open" : hasEmail ? topic.email : "Contact us");
        const methodExternal = hasHref && topic.external;

        return (
          <div class="contact-topics__row" role="row">
            <span class="contact-topics__cell contact-topics__cell--topic">{topic.topic}</span>
            <span class="contact-topics__cell contact-topics__cell--contact">{topic.contactRole}</span>
            <span class="contact-topics__cell contact-topics__cell--method">
              {methodHref ? (
                <a
                  href={methodHref}
                  target={methodExternal ? "_blank" : undefined}
                  rel={methodExternal ? "noopener noreferrer" : undefined}
                >
                  {methodLabel}
                </a>
              ) : (
                <span class="muted small">Get in touch</span>
              )}
              {topic.note ? <div class="contact-topics__note small muted">{topic.note}</div> : null}
            </span>
          </div>
        );
      })}
    </div>
  ) : null}

  {section.details?.map((detail) => {
    if (detail.type === "text") {
      return <p>{detail.content}</p>;
    }

    if (detail.type === "list") {
      return (
        <ul class="contact-section__list">
          {detail.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      );
    }

    return (
      <p>
        <a href={detail.href} target={detail.href.startsWith("http") ? "_blank" : undefined} rel={detail.href.startsWith("http") ? "noopener noreferrer" : undefined}>
          {detail.label}
        </a>
        {detail.description ? <span class="muted small"> — {detail.description}</span> : null}
      </p>
    );
  })}

  {section.actions && (
    <div class="contact-section__actions">
      {section.actions.map((action) => (
        <Button
          key={action.label}
          href={action.href}
          variant={action.variant ?? "secondary"}
          external={action.external}
        >
          {action.label}
        </Button>
      ))}
    </div>
  )}

  {section.ctaGroup ? <ContactCTAGroup {...section.ctaGroup} /> : null}

  {section.showMap && section.mapSrc ? (
    <MapEmbed src={section.mapSrc} title={section.mapTitle} />
  ) : null}

  {section.showSchedule && section.scheduleItems ? (
    <Schedule title={section.scheduleTitle} items={section.scheduleItems} />
  ) : null}

  {section.contactForm ? (
    section.contactForm.available && section.contactForm.href ? (
      <div class="contact-section__form">
        <Button href={section.contactForm.href} external={section.contactForm.external}>
          {section.contactForm.label}
        </Button>
        {section.contactForm.note ? (
          <p class="muted small">{section.contactForm.note}</p>
        ) : null}
      </div>
    ) : (
      <p class="muted small">{section.contactForm.label}</p>
    )
  ) : null}
</section>

<style>
  .contact-section__list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .contact-section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .contact-section__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-topics {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    margin: var(--space-4) 0;
    overflow: hidden;
  }

  .contact-topics__row {
    display: grid;
    grid-template-columns: 3fr 2fr 2fr;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .contact-topics__row--head {
    background: var(--color-bg);
    font-weight: 700;
    border-top: none;
  }

  .contact-topics__note {
    margin-top: 0.25rem;
  }

  @media (max-width: 720px) {
    .contact-topics__row--head {
      display: none;
    }

    .contact-topics__row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
      padding: var(--space-3);
    }

    .contact-topics__cell {
      display: grid;
      gap: var(--space-1);
    }

    .contact-topics__cell::before {
      font-size: var(--font-size-0);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-muted);
    }

    .contact-topics__cell--topic::before {
      content: "Topic";
    }

    .contact-topics__cell--contact::before {
      content: "Contact";
    }

    .contact-topics__cell--method::before {
      content: "Best way to reach them";
    }
  }
</style>
</file>

<file path="web/src/components/sections/AnnualCalendarSection.astro">
---
import { site } from "../../data/site";
import {
  categoryLabels,
  formatDateRange,
  getHighlightEvent,
  splitCalendarEventsByRecency,
  type CalendarFormatters,
} from "../../lib/calendar-utils";

type AnnualEvent = {
  title: string;
  start: string;
  end?: string;
  summary: string;
  location: string;
  category?: string;
  highlight?: boolean;
  closureNote?: string;
  notes?: string;
};

type AnnualCalendar = {
  updatedAt?: string;
  subjectToChange?: string;
  events?: AnnualEvent[];
};

const {
  calendarData = {},
} = Astro.props as {
  calendarData?: AnnualCalendar;
};

const locale = site.locale ?? "en-US";
const timeZone = site.timeZone ?? "UTC";

const events = calendarData.events ?? [];
const updatedDate =
  calendarData.updatedAt && !Number.isNaN(new Date(calendarData.updatedAt).valueOf())
    ? new Date(calendarData.updatedAt)
    : null;

const monthFormatter = new Intl.DateTimeFormat(locale, { month: "long", timeZone });
const monthDayFormatter = new Intl.DateTimeFormat(locale, {
  month: "long",
  day: "numeric",
  timeZone,
});
const yearFormatter = new Intl.DateTimeFormat(locale, { year: "numeric", timeZone });
const updatedFormatter = new Intl.DateTimeFormat(locale, {
  dateStyle: "medium",
  timeZone,
});

const { upcomingEvents, pastEvents } = splitCalendarEventsByRecency(events);
const highlightEvent = getHighlightEvent(upcomingEvents);
const calendarEvents = upcomingEvents.filter((entry) => entry !== highlightEvent);
const formatters: CalendarFormatters = {
  monthFormatter,
  monthDayFormatter,
  yearFormatter,
};

const subjectToChange = calendarData.subjectToChange ?? "Dates are subject to change.";

const updatedCopy = updatedDate
  ? `Last updated ${updatedFormatter.format(updatedDate)}`
  : "Last updated date coming soon.";
---

<section class="stack annual-calendar">
  <p class="muted small annual-calendar__updated">
    {updatedCopy} · {subjectToChange}
  </p>

  {highlightEvent ? (
    <section class="card stack--tight calendar-highlight">
      <div class="cluster--between">
        <div>
          <p class="muted small">
            {categoryLabels[highlightEvent.category ?? "camp"] ?? "Camp meeting"}
          </p>
          <h2>{highlightEvent.title}</h2>
        </div>
        <p class="muted small">
          {formatDateRange(highlightEvent.startDate, highlightEvent.endDate, formatters)}
        </p>
      </div>
      <p class="muted small">Location: {highlightEvent.location}</p>
      <p>{highlightEvent.summary}</p>
      {highlightEvent.closureNote ? (
        <p class="calendar-closure">{highlightEvent.closureNote}</p>
      ) : null}
      {highlightEvent.notes ? <p class="muted small">{highlightEvent.notes}</p> : null}
    </section>
  ) : null}

  <section class="stack">
    <div class="cluster--between">
      <div>
        <h2>Featured dates</h2>
        <p class="muted">These dates help the community plan ahead for worship, service, and outreach.</p>
      </div>
    </div>

    {calendarEvents.length === 0 ? (
      <p class="muted">No upcoming highlight dates are published yet.</p>
    ) : (
      <div class="stack">
        {calendarEvents.map((entry) => (
          <article class="card calendar-event">
            <div class="cluster--between calendar-event__header">
              <p class="muted small">
                {categoryLabels[entry.category ?? "community"] ?? "Event"}
              </p>
                <p class="muted small">
                  {formatDateRange(entry.startDate, entry.endDate, formatters)}
                </p>
            </div>
            <h3>{entry.title}</h3>
            <p class="muted">{entry.summary}</p>
            <p class="muted small">Location: {entry.location}</p>
            {entry.notes ? <p class="muted small">{entry.notes}</p> : null}
          </article>
        ))}
      </div>
    )}
  </section>

  {pastEvents.length > 0 ? (
    <section class="stack">
      <div class="cluster--between">
        <div>
          <h2>Past highlights</h2>
          <p class="muted">Earlier dates stay here for reference after the current season has passed.</p>
        </div>
      </div>

      <div class="stack">
        {pastEvents.map((entry) => (
          <article class="card calendar-event calendar-event--past">
            <div class="cluster--between calendar-event__header">
              <p class="muted small">
                {categoryLabels[entry.category ?? "community"] ?? "Event"}
              </p>
              <p class="muted small">
                {formatDateRange(entry.startDate, entry.endDate, formatters)}
              </p>
            </div>
            <h3>{entry.title}</h3>
            <p class="muted">{entry.summary}</p>
            <p class="muted small">Location: {entry.location}</p>
            {entry.notes ? <p class="muted small">{entry.notes}</p> : null}
          </article>
        ))}
      </div>
    </section>
  ) : null}
</section>

<style>
  .annual-calendar__updated {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .calendar-highlight {
    border-color: var(--color-primary);
    background: var(--color-surface-2);
  }

  .calendar-closure {
    margin: 0;
    font-weight: 600;
    color: var(--color-text);
  }

  .calendar-event__header {
    gap: var(--space-2);
  }

  .calendar-event {
    display: grid;
    gap: var(--space-3);
  }

  .calendar-event--past {
    opacity: 0.9;
  }
</style>
</file>

