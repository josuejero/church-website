<file path="web/src/styles/tokens.css">
/* Design tokens: colors, typography, spacing, radius, shadows
   - Keep these as the single source of truth for styling.
   - All component/page CSS should reference variables from here.
*/

:root {
  /* Typography */
  --font-family-sans: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
    Arial, "Noto Sans", "Liberation Sans", sans-serif;
  --font-family-display: "Bebas Neue", "BebasNeue", var(--font-family-sans);
  --font-family-script: "Signature", var(--font-family-display);

  /* Font sizes (step scale) */
  --font-size-0: 0.9rem;
  --font-size-1: 0.98rem;
  --font-size-2: 1.1rem;
  --font-size-3: 1.28rem;
  --font-size-4: 1.55rem;
  --font-size-5: 2rem;

  /* Type ramp tokens */
  --type-scale-h1-size: var(--font-size-5);
  --type-scale-h1-line-height: 1.25;
  --type-scale-h1-weight: 700;
  --type-scale-h1-letter-spacing: -0.01em;

  --type-scale-h2-size: var(--font-size-4);
  --type-scale-h2-line-height: 1.32;
  --type-scale-h2-weight: 600;
  --type-scale-h2-letter-spacing: 0;

  --type-scale-h3-size: var(--font-size-3);
  --type-scale-h3-line-height: 1.45;
  --type-scale-h3-weight: 600;

  --type-scale-body-size: 1.05rem;
  --type-scale-body-line-height: 1.65;
  --type-scale-body-letter-spacing: 0;

  --type-scale-small-size: 0.82rem;
  --type-scale-small-line-height: 1.45;

  /* Spacing scale (fixes missing vars used across the repo) */
  --space-0: 0;
  --space-1: 0.25rem;  /* 4px */
  --space-2: 0.5rem;   /* 8px */
  --space-3: 0.75rem;  /* 12px */
  --space-4: 1rem;     /* 16px */
  --space-5: 1.25rem;  /* 20px  (was missing) */
  --space-6: 1.5rem;   /* 24px */
  --space-7: 1.75rem;  /* 28px  (was missing) */
  --space-8: 2rem;     /* 32px */
  --space-9: 2.25rem;  /* 36px */
  --space-10: 2.5rem;  /* 40px  (was missing) */
  --space-11: 2.75rem; /* 44px */
  --space-12: 3rem;    /* 48px */
  --space-13: 3.25rem; /* 52px */
  --space-16: 4rem;    /* 64px */
  --space-18: 4.5rem;
  --space-20: 5rem;

  --section-gap: clamp(var(--space-9), 3vw, var(--space-11));
  --section-pad-vertical: clamp(var(--space-6), 3.5vw, var(--space-9));
  --section-pad-horizontal: clamp(var(--space-5), 2vw, var(--space-7));

  /* Radii */
  --radius-2: 0.5rem;
  --radius-3: 0.75rem;
  --radius-4: 1rem;

  /* Shadows */
  --shadow-1: 0 1px 2px rgba(18, 27, 45, 0.06), 0 10px 24px rgba(18, 27, 45, 0.06);
  --shadow-2: 0 8px 20px rgba(18, 27, 45, 0.1), 0 20px 48px rgba(18, 27, 45, 0.08);
  --shadow-card: 0 14px 36px rgba(18, 27, 45, 0.08);
  --shadow-cta: 0 10px 24px rgba(18, 27, 45, 0.18);

  /* Layout */
  --container-max: 84rem;
  --container-pad: 1.75rem;
  --target-min: 44px;

  /* Brand */
  --color-gradient-brand: linear-gradient(135deg, #5c3fd6 0%, #7357ec 55%, #947cff 100%);
  --color-primary: #5c3fd6;
  --color-primary-hover: #4528b7;
  --color-primary-soft: #8b78ff;
  --color-cta-primary: var(--color-primary);
  --color-cta-primary-dark: var(--color-primary-hover);
  --color-cta-secondary: #f4f1ff;
  --color-link: var(--color-primary);
  --color-link-muted: color-mix(in srgb, var(--color-primary) 70%, #ffffff 30%);
  --color-secondary-link: var(--color-link-muted);
  --color-primary-cta: var(--color-cta-primary);
  --color-primary-cta-dark: var(--color-cta-primary-dark);
  --color-primary-cta-soft: var(--color-cta-secondary);
  --color-primary-link: rgba(255, 255, 255, 0.95);

  --color-section-surface: #ffffff;
  --color-section-surface-alt: #f7f8fc;
  --color-section-muted: #f1f3fb;
  --color-section-border: #d9e0ec;
  --color-photo-overlay: rgba(15, 23, 42, 0.55);

  /* Neutrals */
  --color-black: #0f172a;
  --color-text: #1f2937;
  --color-white: #ffffff;
  --color-gray-50: #f8fafc;
  --color-gray-100: #eff3f8;
  --color-gray-200: #dfe6ef;
  --color-gray-300: #cad5e3;
  --color-gray-600: #4b5563;

  /* Surfaces */
  --color-surface: #ffffff;
  --color-surface-alt: var(--color-section-surface-alt);
  --color-surface-2: #eef3f9;
  --color-surface-muted: #f5f7fb;
  --color-bg: #eff4f8;
  --color-border: #d5ddea;
  --color-border-muted: #e4eaf2;
  --color-border-strong: color-mix(in srgb, var(--color-border) 72%, var(--color-primary) 28%);

  /* Text accents */
  --color-text-muted: #586274;
  --color-muted: var(--color-text-muted);

  /* Semantic colors */
  --color-info-border: #224aa8;
  --color-info-bg: #edf3ff;
  --color-warn-border: #f59e0b;
  --color-warn-bg: #fff7ed;
  --color-danger: #b00020;
  --color-danger-border: #b91c1c;
  --color-danger-bg: #fee2e2;
  --color-success-border: #34d399;
  --color-success-bg: #ecfdf5;
  --color-secondary: var(--color-primary-soft);
  --color-primary-700: var(--color-primary-hover);

  /* Focus */
  --color-focus: #244bb2;
  --focus-ring: 3px solid color-mix(in srgb, var(--color-focus) 78%, var(--color-white) 22%);
}
</file>

<file path="web/src/components/sections/HeroBanner.astro">
---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import HeroUI from "../ui/Hero.astro";

export type Props = {
  title: string;
  subtitle?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;

  background: ImageMetadata;

  /**
   * Keep the bridge centered-ish.
   * Example: "50% 55%" (x y)
   */
  objectPosition?: string;
};

const {
  background,
  objectPosition = "50% 55%",
  ...heroProps
} = Astro.props as Props;
const hasMetaSlot = Boolean(Astro.slots?.meta);
const hasWelcomeSlot = Boolean(Astro.slots?.welcome);
---

<section
  class="heroBanner fullbleed"
  style={`--hero-object-position:${objectPosition};`}
>
  <div class="heroBanner__media" aria-hidden="true">
    <Image
      src={background}
      alt=""
      widths={[640, 960, 1280, 1600, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="heroBanner__img"
    />
    <div class="heroBanner__scrim" aria-hidden="true"></div>
  </div>

  <div
    class:list={[
      "heroBanner__content",
      !hasWelcomeSlot && "heroBanner__content--solo",
    ]}
  >
    {hasWelcomeSlot ? (
      <div class="heroBanner__content-grid heroBanner__content-grid--with-welcome">
        <div class="heroBanner__welcome-card">
          <slot name="welcome" />
        </div>
        <div class="heroBanner__hero-card">
          <HeroUI {...heroProps} className="hero-card">
            {hasMetaSlot ? <slot name="meta" slot="meta" /> : null}
          </HeroUI>
        </div>
      </div>
    ) : (
      <HeroUI {...heroProps} className="hero-card">
        {hasMetaSlot ? <slot name="meta" slot="meta" /> : null}
      </HeroUI>
    )}
  </div>
</section>

<style>
  .heroBanner {
    position: relative;
    min-height: clamp(30rem, 68vh, 50rem);
    border: 1px solid var(--color-section-border);
    border-radius: var(--radius-4);
    overflow: hidden;
    --hero-content-offset-x: clamp(var(--space-4), 3vw, var(--space-7));
    --hero-content-offset-y: clamp(var(--space-5), 4vw, var(--space-8));
    --hero-content-offset-bottom: clamp(var(--space-7), 6vw, var(--space-9));
    background: var(--color-section-muted);
    box-shadow: var(--shadow-card);
  }

  .heroBanner__media {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
  }

  .heroBanner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-object-position);
    transform: scale(1.015);
    border-radius: inherit;
  }

  .heroBanner__scrim {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      165deg,
      rgba(5, 5, 10, 0.85) 0%,
      rgba(5, 5, 10, 0.45) 45%,
      rgba(5, 5, 10, 0.9) 100%
    );
    backdrop-filter: blur(2px) saturate(112%);
    -webkit-backdrop-filter: blur(2px) saturate(112%);
  }

  .heroBanner__content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: flex-start;
    align-items: flex-end;
    width: 100%;
    min-height: 100%;
    padding:
      var(--hero-content-offset-y)
      var(--hero-content-offset-x)
      var(--hero-content-offset-bottom);
  }

  .heroBanner__content--solo {
    align-items: flex-start;
  }

  .heroBanner__content-grid--with-welcome {
    width: min(1200px, 100%);
    margin: 0;
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(360px, 1fr);
    gap: clamp(var(--space-5), 3vw, var(--space-7));
    align-items: stretch;
    justify-content: flex-start;
  }

  .heroBanner__welcome-card,
  .heroBanner__hero-card {
    width: 100%;
  }

  .heroBanner__content-grid--with-welcome :global(.hero.card) {
    width: 100%;
    max-width: 100%;
  }

  .heroBanner__welcome-card {
    align-self: stretch;
  }

  .heroBanner__hero-card {
    align-self: stretch;
  }

  /* Keep the existing “card” look, but keep it a compact width on large screens */
  :global(.heroBanner .hero.card) {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.88) 100%
    );
    border-color: var(--color-section-border);
    border-radius: var(--radius-4);
    box-shadow: var(--shadow-card);
    width: min(520px, calc(100% - 2 * var(--hero-content-offset-x)));
    max-width: min(520px, calc(100% - 2 * var(--hero-content-offset-x)));
    padding: clamp(var(--space-5), 2vw, var(--space-7));
  }

  @media (max-width: 720px) {
    .heroBanner {
      min-height: clamp(21rem, 48vh, 30rem);
      --hero-content-offset-x: var(--space-4);
      --hero-content-offset-y: var(--space-4);
      --hero-content-offset-bottom: var(--space-5);
      --hero-object-position: 50% 50%;
    }

    :global(.heroBanner .hero.card) {
      padding: var(--space-4);
    }
  }

  @media (max-width: 960px) {
    .heroBanner__content-grid--with-welcome {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .heroBanner__hero-card {
      order: 1;
    }

    .heroBanner__welcome-card {
      order: 2;
    }

    .heroBanner__content {
      align-items: center;
    }

    .heroBanner__content > :global(.hero.card) {
      width: 100%;
      max-width: 100%;
    }
  }

  @media (prefers-reduced-data: reduce) {
    .heroBanner__media {
      display: none;
    }
    .heroBanner {
      background: var(--color-surface-2);
    }
  }
</style>
</file>

<file path="web/src/components/global/Header.astro">
---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import churchLogo from "../../assets/photos/church-logo-primary.jpg";
import { site } from "../../data/site";

const pathname = Astro.url?.pathname ?? "/";

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}

function linkAttrs(item: { href: string; external?: boolean }) {
  return item.external ? { target: "_blank", rel: "noopener noreferrer" } : {};
}

const primaryNav = site.nav;
const utilityLinks = site.utilityLinks ?? [];

const watchLive =
  site.quickActions.find((i) => i.label === "Watch Live") ??
  site.quickActions[0];
const give =
  site.quickActions.find((i) => i.label === "Give") ?? site.quickActions[1];
const otherQuick = site.quickActions.filter(
  (i) => i.label !== watchLive?.label && i.label !== give?.label,
);
const brandAriaLabel = `${site.shortName} – ${site.name}`;
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href="/" aria-label={brandAriaLabel}>
      <Image
        src={churchLogo}
        alt={`${site.name} logo`}
        widths={[36, 44, 56]}
        sizes="48px"
        loading="eager"
        decoding="async"
        class="brand__logo"
      />
      <span class="brand__title signature-text">{site.shortName}</span>
    </a>

    <nav class="nav nav--desktop" aria-label="Primary navigation">
      {
        primaryNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            {...linkAttrs(item)}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="right">
      <div class="cta cta--desktop" aria-label="Primary actions">
        {
          watchLive && (
            <Button
              href={watchLive.href}
              variant="secondary"
              size="sm"
              external={!!watchLive.external}
            >
              {watchLive.label}
            </Button>
          )
        }
        {
          give && (
            <Button
              href={give.href}
              variant="primary"
              size="sm"
              external={!!give.external}
            >
              {give.label}
            </Button>
          )
        }
      </div>

      <div class="cta cta--mobile" aria-label="Primary actions">
        {
          watchLive && (
            <Button
              href={watchLive.href}
              variant="secondary"
              size="sm"
              external={!!watchLive.external}
            >
              {watchLive.label}
            </Button>
          )
        }
        {
          give && (
            <Button
              href={give.href}
              variant="primary"
              size="sm"
              external={!!give.external}
            >
              {give.label}
            </Button>
          )
        }
      </div>

      <details class="menu" aria-label="Mobile menu">
        <summary class="menu__summary" aria-label="Open menu">
          <span class="menu__icon" aria-hidden="true">☰</span>
          <span class="menu__label">Menu</span>
        </summary>

        <div class="menu__panel">
          <nav class="menu__section" aria-label="Primary navigation">
            {
              site.nav.map((item) => (
                <a
                  class="menu__link"
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  {...linkAttrs(item)}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>

          {
            otherQuick.length > 0 && (
              <>
                <div
                  class="menu__divider"
                  role="separator"
                  aria-hidden="true"
                />

                <div class="menu__section" aria-label="Quick links">
                  <p class="menu__section-title">Quick links</p>
                  <div class="menu__quicklinks" aria-label="More quick links">
                    {otherQuick.map((item) => (
                      <a
                        class="menu__sublink"
                        href={item.href}
                        {...linkAttrs(item)}
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            )
          }

          {
            utilityLinks.length > 0 && (
              <>
                <div
                  class="menu__divider"
                  role="separator"
                  aria-hidden="true"
                />

                <div class="menu__section" aria-label="More links">
                  <p class="menu__section-title">More links</p>
                  {utilityLinks.map((item) => (
                    <a class="menu__link" href={item.href} {...linkAttrs(item)}>
                      {item.label}
                    </a>
                  ))}
                </div>
              </>
            )
          }
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector(".site-header");

  if (header instanceof HTMLElement) {
    const menu = header.querySelector("details.menu");
    const summary = menu?.querySelector("summary.menu__summary");

    if (menu instanceof HTMLDetailsElement && summary instanceof HTMLElement) {
      const desktopNavBreakpoint = window.matchMedia("(max-width: 1100px)");

      const syncMenuLabel = () => {
        const label = menu.open ? "Close menu" : "Open menu";
        summary.setAttribute("aria-label", label);
        summary.setAttribute("aria-expanded", String(menu.open));
      };

      const closeMenu = (restoreFocus = false) => {
        if (!menu.open) return;
        menu.open = false;
        if (restoreFocus) summary.focus();
      };

      syncMenuLabel();
      menu.addEventListener("toggle", syncMenuLabel);

      document.addEventListener("click", (event) => {
        if (!menu.open) return;

        const target = event.target;
        if (!(target instanceof Node)) return;

        if (target instanceof Element) {
          const link = target.closest("a");
          if (link && menu.contains(link)) {
            closeMenu();
            return;
          }
        }

        if (!menu.contains(target)) {
          closeMenu();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape" || !menu.open) return;
        event.preventDefault();
        closeMenu(true);
      });

      const handleBreakpointChange = (event: MediaQueryListEvent) => {
        if (!event.matches) closeMenu();
      };

      if (typeof desktopNavBreakpoint.addEventListener === "function") {
        desktopNavBreakpoint.addEventListener("change", handleBreakpointChange);
      } else {
        desktopNavBreakpoint.addListener(handleBreakpointChange);
      }
    }
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(
      in srgb,
      var(--color-section-surface) 92%,
      #ffffff 8%
    );
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    box-shadow: 0 14px 35px rgba(5, 6, 30, 0.12);
    backdrop-filter: saturate(180%) blur(20px);
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-3) var(--container-pad);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
  }

  .menu__section-title {
    margin: 0;
    font-size: var(--font-size-0);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .brand {
    text-decoration: none;
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .brand__logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-3);
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand__title {
    font-weight: 600;
    letter-spacing: 0.12em;
    font-size: clamp(1.2rem, 1.05rem + 0.7vw, 1.55rem);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.35rem, 0.9vw, 0.8rem);
    justify-content: center;
    flex-wrap: nowrap;
    min-width: 0;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    font-weight: 700;
    font-size: clamp(0.84rem, 0.8rem + 0.22vw, 0.95rem);
    opacity: 0.9;
    padding: 0.5rem 0.62rem;
    min-width: auto;
    justify-content: center;
    border-radius: 999px;
    white-space: nowrap;
  }

  .nav a:hover {
    background: color-mix(
      in srgb,
      var(--color-primary) 12%,
      var(--color-surface) 88%
    );
    opacity: 1;
  }

  .nav a[aria-current="page"] {
    background: color-mix(
      in srgb,
      var(--color-primary) 25%,
      var(--color-primary-soft) 75%
    );
    color: var(--color-white);
    opacity: 1;
    box-shadow: 0 8px 20px rgba(13, 8, 55, 0.25);
  }

  .cta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    justify-content: flex-end;
    min-width: 0;
  }

  .right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-2);
    min-width: 0;
    position: relative;
  }

  .cta--mobile {
    display: none;
  }

  /* Mobile menu */
  .menu {
    display: none;
  }

  .menu__summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    padding: 0.65rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-section-surface);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    min-height: var(--target-min);
    min-width: var(--target-min);
    width: 100%;
    justify-content: center;
    max-width: 200px;
  }

  .menu__summary::-webkit-details-marker {
    display: none;
  }

  .menu[open] .menu__summary {
    background: color-mix(
      in srgb,
      var(--color-primary-soft) 18%,
      var(--color-section-surface) 82%
    );
  }

  .menu__panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    right: 0;
    max-width: min(28rem, calc(100vw - 2 * var(--container-pad)));
    max-height: calc(100vh - 8rem);
    max-height: calc(100dvh - 8rem);
    background: var(--color-section-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    padding: var(--space-3);
    z-index: 60;
    box-sizing: border-box;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .menu__section {
    display: grid;
    gap: var(--space-2);
    width: 100%;
  }

  .menu__link {
    display: flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    font-weight: 700;
    padding: 0.6rem 0.7rem;
    border-radius: var(--radius-2);
  }

  .menu__link:hover {
    background: color-mix(
      in srgb,
      var(--color-primary-soft) 12%,
      var(--color-section-surface) 88%
    );
  }

  .menu__link[aria-current="page"] {
    background: color-mix(
      in srgb,
      var(--color-primary) 24%,
      var(--color-primary-soft) 76%
    );
    color: var(--color-white);
    box-shadow: 0 8px 18px rgba(13, 8, 55, 0.22);
  }

  .menu__divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-3) 0;
  }

  .menu__quicklinks {
    margin-top: var(--space-3);
    display: grid;
    gap: 0.25rem;
  }

  .menu__sublink {
    display: inline-flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    opacity: 0.85;
    padding: 0.4rem 0.2rem;
    font-weight: 700;
  }

  .menu__sublink:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .cta--desktop {
      display: none;
    }

    .cta--mobile {
      display: flex;
    }

    .menu {
      display: block;
    }

    .nav--desktop {
      display: none;
    }

    .inner {
      grid-template-columns: auto 1fr auto;
      gap: var(--space-2);
    }
  }

  @media (max-width: 860px) {
    .inner {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto;
      gap: var(--space-2);
    }

    .brand {
      grid-row: 1;
    }

    .brand__title {
      white-space: nowrap;
    }

    .right {
      grid-column: 1;
      grid-row: 2;
      justify-content: space-between;
    }

    .cta--mobile {
      flex: 1;
      justify-content: flex-start;
    }

    .cta--mobile .btn {
      min-width: 0;
      padding-inline: var(--space-3);
    }

    .right {
      gap: var(--space-1);
    }
  }

  @media (max-width: 420px) {
    .brand__title {
      font-size: 1.08rem;
      letter-spacing: 0.08em;
    }

    .cta--mobile .btn {
      padding-inline: var(--space-2);
    }

    .menu__label {
      display: none;
    }

    .menu__summary {
      padding: 0.55rem 0.6rem;
    }

    .nav a {
      padding: 0.45rem 0.56rem;
    }
  }
</style>
</file>

<file path="web/src/styles/global.css">
@import "@fontsource/poppins/400.css";
@import "@fontsource/poppins/500.css";
@import "@fontsource/poppins/600.css";
@import "@fontsource/poppins/700.css";
@import "@fontsource/bebas-neue/400.css";
@import url("https://fonts.googleapis.com/css2?family=Signature&display=swap");
@import "./tokens.css";

/* Global baseline styles
   - Low-specificity defaults
   - Utility classes
   - Layout primitives
*/

:root {
  color-scheme: light;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  padding: 0;
  margin: 0;
}

body {
  font-family: var(--font-family-sans);
  color: var(--color-text);
  background:
    radial-gradient(circle at top, rgba(139, 120, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f8fafd 0%, var(--color-bg) 100%);
  background-attachment: scroll;
  font-size: var(--type-scale-body-size);
  line-height: var(--type-scale-body-line-height);
}

.signature-text {
  font-family: var(--font-family-script);
  letter-spacing: 0.05em;
  color: var(--color-primary);
}

img {
  max-width: 100%;
  height: auto;
}

a {
  color: var(--color-link);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 0.18em;
  text-decoration-thickness: 0.16em;
}

a:hover {
  color: var(--color-primary);
  text-decoration-thickness: 0.19em;
}

/* Focus styles (WCAG-friendly: visible, thick enough, offset from element) */
:where(
  a,
  button,
  summary,
  input,
  select,
  textarea,
  [role="button"],
  [tabindex]
):focus-visible {
  outline: var(--focus-ring);
  outline-offset: 3px;
}

/* Prevent accidental focus rings when clicking */
:where(
    a,
    button,
    summary,
    input,
    select,
    textarea,
    [role="button"],
    [tabindex]
  ):focus:not(:focus-visible) {
  outline: none;
}

.container {
  width: 100%;
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--container-pad);
  display: block;
}

.main {
  padding: clamp(var(--space-6), 3.4vw, var(--space-10)) 0;
}

h1,
h2,
h3,
h4 {
  margin: 0;
  font-weight: 700;
}

h1 {
  font-size: var(--type-scale-h1-size);
  line-height: var(--type-scale-h1-line-height);
  font-weight: var(--type-scale-h1-weight);
  letter-spacing: var(--type-scale-h1-letter-spacing);
}

h2 {
  font-size: var(--type-scale-h2-size);
  line-height: var(--type-scale-h2-line-height);
  font-weight: var(--type-scale-h2-weight);
  letter-spacing: var(--type-scale-h2-letter-spacing);
}

h3 {
  font-size: var(--type-scale-h3-size);
  line-height: var(--type-scale-h3-line-height);
  font-weight: var(--type-scale-h3-weight);
}

h4 {
  font-size: var(--font-size-2);
  line-height: 1.4;
}

p {
  margin: 0;
  font-size: var(--type-scale-body-size);
  line-height: var(--type-scale-body-line-height);
  color: var(--color-text);
}

.small {
  font-size: var(--type-scale-small-size);
  line-height: var(--type-scale-small-line-height);
}

.text-body {
  font-size: var(--type-scale-body-size);
  line-height: var(--type-scale-body-line-height);
  color: var(--color-text);
}

.section-heading {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin: 0;
}

.section-heading--horizontal {
  flex-direction: row;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-4);
}

.section-heading__copy {
  min-width: 0;
  flex: 1;
}

.section-heading__action {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  justify-content: flex-end;
}

.section-heading__action > * {
  flex-shrink: 0;
}

.section-heading__title {
  margin: 0;
  font-size: clamp(1.45rem, 1.2rem + 0.86vw, 1.9rem);
  line-height: 1.2;
  font-family: var(--font-family-display);
  letter-spacing: 0.02em;
}

.section-heading__subtitle {
  margin: 0;
  color: var(--color-text-muted);
  font-size: clamp(0.98rem, 0.95rem + 0.2vw, 1.08rem);
  line-height: 1.58;
}
.surface-section,
.section-block {
  padding: var(--section-pad-vertical) var(--section-pad-horizontal);
  background: var(--color-section-surface);
  border-radius: var(--radius-4);
  border: 1px solid var(--color-section-border);
  box-shadow: var(--shadow-card);
}

.surface-section:nth-of-type(even) {
  background: var(--color-section-surface-alt);
  border-color: color-mix(in srgb, var(--color-section-border) 60%, var(--color-section-surface-alt) 40%);
}

section {
  margin: var(--section-gap) 0;
}

section:first-of-type {
  margin-top: 0;
}
.muted {
  color: var(--color-text-muted);
}
.text-on-dark {
  color: var(--color-text);
}
.text-on-dark h1,
.text-on-dark h2,
.text-on-dark h3,
.text-on-dark h4,
.text-on-dark .section-heading__title {
  color: var(--color-text);
}
.text-on-dark p,
.text-on-dark li,
.text-on-dark .section-heading__subtitle {
  color: var(--color-text);
}
.text-on-dark .muted {
  color: var(--color-text-muted);
}
.center {
  text-align: center;
}

button {
  font: inherit;
}

hr {
  border: 0;
  border-top: 1px solid var(--color-border);
  margin: var(--space-6) 0;
}

/* Card utility */
.card {
  background: var(--color-surface-alt);
  border: 1px solid var(--color-section-border);
  border-radius: var(--radius-4);
  padding: var(--space-5);
  box-shadow: var(--shadow-1);
  transition:
    box-shadow 180ms ease,
    border-color 180ms ease,
    transform 180ms ease;
  color: var(--color-text);
}

:where(
  .surface-section,
  .section-block,
  .card,
  .hero,
  .banner,
  .highlights-carousel,
  .connect-card__form,
  .prayer-callout,
  .activity-card,
  .weekly-highlights__card,
  .budget-progress,
  .schedule
) {
  color: var(--color-text);
}

.card--muted {
  background: var(--color-section-muted);
  border-color: color-mix(in oklab, var(--color-section-border) 70%, var(--color-section-muted) 30%);
}

.card--featured {
  box-shadow: var(--shadow-2);
  border-color: color-mix(
    in oklab,
    var(--color-border) 72%,
    var(--color-primary) 28%
  );
}

.card--link {
  display: block;
  color: inherit;
  text-decoration: none;
  transition:
    transform 160ms ease,
    box-shadow 160ms ease,
    border-color 160ms ease;
}

.card--link:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-2);
  border-color: color-mix(
    in srgb,
    var(--color-border) 70%,
    var(--color-primary) 30%
  );
}

.card--link:focus-visible {
  outline: var(--focus-ring);
  outline-offset: 3px;
}

.link {
  color: var(--color-link);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 0.18em;
  text-decoration-thickness: 0.19em;
}

/* Badges + chips (used in /components and content pages) */
.badge,
.chip {
  display: inline-flex;
  align-items: center;
  min-height: 1.8rem;
  padding: 0.15rem 0.55rem;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: color-mix(in oklab, var(--color-surface) 92%, black 8%);
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  line-height: 1.2;
}

.chip--tag {
  font-weight: 600;
  border-color: color-mix(in oklab, var(--color-border) 80%, var(--color-text-muted) 20%);
  background: color-mix(in oklab, var(--color-surface) 88%, var(--color-border) 12%);
  color: var(--color-text);
}

.badge--primary {
  border-color: color-mix(
    in oklab,
    var(--color-primary) 45%,
    var(--color-border) 55%
  );
  background: color-mix(
    in srgb,
    var(--color-primary) 12%,
    var(--color-surface) 88%
  );
  color: var(--color-primary);
}

.badge--warn {
  border-color: var(--color-warn-border);
  background: var(--color-warn-bg);
}

.badge--urgent {
  border-color: var(--color-danger-border);
  background: var(--color-danger-bg);
}

/* Tag list */
.tags {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  align-items: center;
  padding: 0;
  margin: 0;
}

/* Forms */
.form {
  display: grid;
  gap: var(--space-6);
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.form label {
  font-weight: 700;
}

.form :where(input, select, textarea) {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2);
  padding: var(--space-3);
  font: inherit;
  background: var(--color-white);
}

.form :where(input, select, textarea)::placeholder {
  color: color-mix(in oklab, var(--color-text-muted) 70%, transparent 30%);
}

.form :where(textarea) {
  resize: vertical;
  min-height: 6rem;
}

.required {
  margin-left: 0.25rem;
  color: var(--color-secondary);
}

.form-helper {
  display: block;
  font-size: var(--font-size-0);
  color: var(--color-text-muted);
  font-weight: 400;
}

.form-error {
  margin: 0;
  font-size: var(--font-size-0);
  color: var(--color-danger);
}

/* Prose / rich text */
.prose > * {
  margin: 0;
}
.prose > * + * {
  margin-top: var(--space-4);
}

.prose :where(h2, h3, h4) {
  margin-top: var(--space-6);
  margin-bottom: var(--space-2);
}

.prose :where(ul, ol) {
  padding-left: 1.4rem;
}
.prose :where(li + li) {
  margin-top: var(--space-2);
}

.prose :where(blockquote) {
  margin-left: 0;
  padding-left: var(--space-4);
  border-left: 3px solid var(--color-border);
  color: var(--color-text-muted);
}

.prose :where(code) {
  font-family:
    ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
  font-size: 0.95em;
  padding: 0.1rem 0.3rem;
  border-radius: 0.4rem;
  background: color-mix(in oklab, var(--color-surface-2) 80%, black 20%);
}

.prose :where(pre) {
  overflow: auto;
  padding: var(--space-4);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-3);
  background: var(--color-surface-2);
}

.prose :where(pre code) {
  padding: 0;
  background: transparent;
  border-radius: 0;
}

.prose :where(table) {
  width: 100%;
  border-collapse: collapse;
  border: 1px solid var(--color-border);
}

.prose :where(th, td) {
  border-top: 1px solid var(--color-border);
  padding: var(--space-2) var(--space-3);
  text-align: left;
  vertical-align: top;
}

.prose :where(th) {
  background: var(--color-surface-2);
  font-weight: 800;
}

.prose :where(img) {
  border-radius: var(--radius-3);
  border: 1px solid var(--color-border);
}

/* Layout utilities */
.stack,
.stack--tight,
.stack--loose {
  display: grid;
}

.stack {
  gap: var(--section-gap);
}
.stack--tight {
  gap: var(--space-4);
}
.stack--loose {
  gap: var(--space-16);
}

.stack > *,
.stack--tight > *,
.stack--loose > * {
  margin: 0;
}

.cluster {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-3);
}

.cluster--between {
  justify-content: space-between;
}
.cluster--baseline {
  align-items: baseline;
}
.cluster--loose {
  gap: var(--space-4);
}

.grid {
  display: grid;
  gap: var(--space-3);
}

.grid--cards {
  display: grid;
  gap: var(--space-3);
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
}

.adventurer-cta {
  align-items: stretch;
  gap: clamp(var(--space-4), 1.2vw, var(--space-6));
}

.adventurer-cta__guide {
  margin: 0;
  font-size: var(--font-size-0);
  line-height: 1.4;
  color: var(--color-text-muted);
}

.adventurer-cta__card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 240px;
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.adventurer-cta__card:hover,
.adventurer-cta__card:focus-within {
  transform: translateY(-3px);
  border-color: color-mix(in oklab, var(--color-primary) 45%, var(--color-border) 55%);
  box-shadow: var(--shadow-2);
}

.adventurer-cta__card:focus-within {
  outline: var(--focus-ring);
  outline-offset: 4px;
}

.adventurer-cta__action {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.adventurer-cta__note {
  margin: 0;
  font-size: var(--font-size-0);
  line-height: 1.4;
}

.memo-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.memo-actions__note {
  margin: 0;
  font-size: var(--font-size-0);
  color: var(--color-text-muted);
}

.skip-link {
  position: absolute;
  top: var(--space-2);
  left: var(--space-2);
  padding: var(--space-2) var(--space-3);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2);
  text-decoration: none;
  transform: translateY(-200%);
  transition: transform 120ms ease;
  z-index: 999;
}

.skip-link:focus {
  transform: translateY(0);
}

@media (max-width: 860px) {
  :root {
    --container-pad: 1rem;
  }

  .main {
    padding: var(--space-6) 0;
  }
}

@media (max-width: 640px) {
  :root {
    --section-gap: var(--space-6);
    --section-pad-vertical: var(--space-6);
    --section-pad-horizontal: var(--space-4);
  }

  .container {
    padding-inline: 1rem;
  }

  .main {
    padding: var(--space-5) 0;
  }

  .stack,
  .stack--tight,
  .stack--loose {
    gap: var(--space-4);
  }

  .cluster,
  .cluster--between,
  .cluster--baseline,
  .cluster--loose {
    flex-direction: column;
    align-items: stretch;
  }

  .cluster > * {
    width: 100%;
  }

  .btn {
    width: 100%;
    justify-content: center;
  }
}

@media (max-width: 720px) {
  .card {
    padding: var(--space-4);
  }

  .stack {
    gap: var(--space-4);
  }

  .stack--loose {
    gap: var(--space-6);
  }

  .grid--cards {
    gap: var(--space-3);
  }
}

@media (max-width: 420px) {
  :root {
    --container-pad: 0.875rem;
  }
}
</file>

