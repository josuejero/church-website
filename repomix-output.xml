  }

  .component-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--color-border);
  }

  .component-table th,
  .component-table td {
    padding: var(--space-3);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .component-table th {
    font-size: var(--font-size-0);
