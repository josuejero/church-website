<file path="web/.github/workflows/ci.yml">
name: CI

on:
  pull_request:
  push:
    branches: ["main", "master"]

jobs:
  web:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: web

    env:
      # Ensures canonical URLs + sitemap/robots generation are deterministic in CI
      PUBLIC_SITE_URL: http://127.0.0.1:4321

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
          cache-dependency-path: web/package-lock.json

      - name: Install dependencies
        run: npm ci

      - name: Typecheck
        run: npm run check

      - name: Build
        run: npm run build

      - name: Install Playwright browsers
        run: npx playwright install --with-deps

      - name: E2E tests
        run: npm run test:e2e:ci

      - name: Internal link check
        run: npm run test:links:ci

      - name: Lighthouse CI
        run: npm run lighthouse:ci

      - name: Upload Lighthouse artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: lighthouseci
          path: web/.lighthouseci

      - name: Upload Playwright report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report
          path: web/playwright-report
</file>

<file path="web/src/components/sections/LiveCalendarPreview.astro">
---
import Button from "../ui/Button.astro";

type Props = {
  title?: string;
  description?: string;
  embedUrl?: string;
  note?: string;
  compact?: boolean;
};

const {
  title = "Live campus calendar",
  description = "The public calendar shows the most current schedule for services, ministries, and outreach.",
  embedUrl,
  note,
  compact = false,
} = Astro.props as Props;

const hasEmbed = typeof embedUrl === "string" && embedUrl.trim().length > 0;
const fallbackNote = hasEmbed
  ? "This embed shows the live campus schedule."
  : "The live calendar embed is pending; consult the annual calendar page while we finalize the official feed.";
const displayNote = note ?? fallbackNote;
const iframeHeight = compact ? 280 : 520;
const iframeTitle = `${title} preview`;
---
<section class="live-calendar stack surface-section">
  <div>
    <h2>{title}</h2>
    <p class="muted small">{description}</p>
  </div>
  <div class="live-calendar__embed" aria-live="polite">
    {hasEmbed ? (
      <div
        class="live-calendar__embed-placeholder live-calendar__embed-placeholder--embed"
        data-live-calendar-embed
        data-live-calendar-embed-url={embedUrl}
        data-live-calendar-iframe-title={iframeTitle}
        data-live-calendar-iframe-height={iframeHeight}
        style={`min-height:${iframeHeight}px`}
      >
        <p class="live-calendar__embed-placeholder-title">Load the live campus calendar</p>
        <p class="live-calendar__embed-placeholder-copy">
          The shared calendar runs on Google&apos;s embed and stays inactive until you explicitly load it, keeping
          third-party cookies dormant until you decide to view the feed.
        </p>
        <div class="live-calendar__embed-placeholder-actions">
          <Button data-live-calendar-trigger variant="secondary">
            Load live calendar
          </Button>
          <p class="muted small live-calendar__embed-placeholder-note">
            Loading the embed will open the current schedule straight from Google Calendar.
          </p>
        </div>
      </div>
    ) : (
      <div class="live-calendar__embed-placeholder" style={`min-height:${iframeHeight}px`}>
        <p class="live-calendar__embed-placeholder-title">Live calendar coming soon</p>
        <p class="live-calendar__embed-placeholder-copy">
          We are working to publish the official public calendar. Meanwhile, the annual events timeline and the local
          calendar page summarize the most important services, ministries, and outreach.
        </p>
        <a class="live-calendar__embed-placeholder-link" href="/calendar">Explore the annual calendar page</a>
      </div>
    )}
  </div>
  <p class="muted live-calendar__note">{displayNote}</p>
</section>

<style>
  .live-calendar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .live-calendar__embed {
    width: 100%;
    background: var(--color-surface-muted);
    border-radius: var(--radius-4);
    overflow: hidden;
    border: 1px solid var(--color-border-muted);
  }

  .live-calendar__embed iframe {
    width: 100%;
    display: block;
  }

  .live-calendar__embed-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    justify-content: center;
    padding: var(--space-5) var(--space-4);
    color: var(--color-text-muted);
  }

  .live-calendar__embed-placeholder-title {
    margin: 0;
    font-weight: 600;
  }

  .live-calendar__embed-placeholder-copy {
    margin: 0;
    line-height: 1.4;
  }

  .live-calendar__embed-placeholder--embed {
    align-items: flex-start;
  }

  .live-calendar__embed-placeholder-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .live-calendar__embed-placeholder-note {
    margin: 0;
    max-width: 40rem;
  }

  .live-calendar__embed-placeholder-link {
    color: var(--color-link);
    font-weight: 500;
    text-decoration: underline;
  }

  .live-calendar__note {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .live-calendar__embed iframe {
      height: 420px;
    }
    .live-calendar__embed-placeholder {
      min-height: 280px;
    }
  }
</style>

<script is:inline type="module">
  const loadLiveCalendarIframe = (container) => {
    if (!container || container.dataset.liveCalendarLoaded === "true") {
      return;
    }
    const iframeUrl = container.dataset.liveCalendarEmbedUrl;
    if (!iframeUrl) {
      return;
    }
    const iframe = document.createElement("iframe");
    iframe.src = iframeUrl;
    iframe.title = container.dataset.liveCalendarIframeTitle || "Live calendar preview";
    iframe.loading = "lazy";
    iframe.allowFullscreen = true;
    iframe.referrerPolicy = "no-referrer";
    iframe.style.border = "0";
    iframe.style.width = "100%";
    const height = container.dataset.liveCalendarIframeHeight;
    if (height) {
      iframe.setAttribute("height", height);
    }
    container.innerHTML = "";
    container.appendChild(iframe);
    container.dataset.liveCalendarLoaded = "true";
  };

  const attachLiveCalendarTriggers = () => {
    document.querySelectorAll("[data-live-calendar-embed]").forEach((container) => {
      if (container.dataset.liveCalendarInit === "true") {
        return;
      }
      container.dataset.liveCalendarInit = "true";
      const trigger = container.querySelector("[data-live-calendar-trigger]");
      if (!trigger) {
        return;
      }
      trigger.addEventListener(
        "click",
        (event) => {
          event.preventDefault();
          loadLiveCalendarIframe(container);
        },
        { once: true },
      );
    });
  };

  if (document.readyState === "loading") {
    window.addEventListener("DOMContentLoaded", attachLiveCalendarTriggers);
  } else {
    attachLiveCalendarTriggers();
  }
</script>
</file>

