  }

  .component-label {
    margin: 0;
    font-size: var(--font-size-0);
    color: var(--color-text-muted);
  }

  .component-hint {
    margin-top: var(--space-3);
    font-size: var(--font-size-0);
    color: var(--color-text-muted);
  }

  .component-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3);
    padding: var(--space-3);
