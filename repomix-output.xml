    text-transform: uppercase;
    letter-spacing: 0.11em;
    padding: 0.28rem 0.72rem;
    border-radius: 999px;
  }

  .highlights-carousel__badge {
    background: color-mix(
      in oklab,
      var(--color-surface-muted) 70%,
      var(--color-primary) 30%
    );
