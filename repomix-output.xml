<style>
  .budget-progress {
    gap: var(--space-4);
    display: flex;
    flex-direction: column;
    color: var(--color-text);
  }

  .budget-progress__heading {
    display: grid;
    gap: var(--space-1);
  }

  .budget-progress__heading > .muted {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .budget-progress__heading h2 {
    margin: 0;
    font-size: clamp(1.25rem, 1.07rem + 0.58vw, 1.55rem);
  }

  .budget-progress__totals {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-3);
  }

  .budget-progress__totals > div {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    background: color-mix(
      in oklab,
      var(--color-surface) 94%,
      var(--color-surface-muted) 6%
    );
    padding: var(--space-3);
    display: grid;
    gap: 0.1rem;
  }

  .budget-progress__amount {
    margin: 0;
    font-size: clamp(1.25rem, 1.02rem + 0.7vw, 1.6rem);
    font-weight: 700;
  }

  .budget-progress__bar {
    position: relative;
    height: 14px;
    background: var(--color-surface-muted);
    border-radius: var(--radius-4);
    overflow: hidden;
    border: 1px solid
      color-mix(in oklab, var(--color-border) 78%, var(--color-primary) 22%);
  }

  .budget-progress__bar-fill {
    display: block;
    height: 100%;
    background: linear-gradient(
      90deg,
      color-mix(
          in oklab,
          var(--color-primary-700) 50%,
          var(--color-primary) 50%
        )
        0%,
      #8c222b 50%,
      #a32933 100%
    );
    border-radius: var(--radius-4);
    transition: width 220ms ease;
  }

  .budget-progress__percent {
    margin: 0;
    font-weight: 600;
  }

  .budget-progress__updated {
    margin: 0;
  }
</style>
</file>

