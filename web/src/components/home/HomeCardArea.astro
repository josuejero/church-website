---
import CardGrid from "../sections/CardGrid.astro";
import type { HomeCardItem } from "../../data/homeContent";

type Props = {
  title: string;
  subtitle: string;
  cards: HomeCardItem[];
  modifier?: string;
  columnsMin?: number;
};

const {
  title,
  subtitle,
  cards,
  modifier = "",
  columnsMin = 220,
} = Astro.props as Props;

const gridClasses = ["home-card-area", modifier, "surface-section"].filter(Boolean).join(" ");
---

<CardGrid title={title} subtitle={subtitle} cards={cards} columnsMin={columnsMin} class={gridClasses} />
