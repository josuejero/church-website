---
import Button from "../ui/Button.astro";
import EventList from "../sections/EventList.astro";
import LiveCalendarPreview from "../sections/LiveCalendarPreview.astro";
import HomeHeroSection from "./HomeHeroSection.astro";
import HomeCardArea from "./HomeCardArea.astro";
import HomeGivingBlock from "./HomeGivingBlock.astro";
import HomeVisitSection from "./HomeVisitSection.astro";
import type { Cta, GivingContent, HeroConfig, HomeCardItem } from "../../data/homeContent";
import { site } from "../../data/site";

const {
  heroConfig,
  heroMeta,
  nextStepCards,
  givingContent,
} = Astro.props as {
  heroConfig: HeroConfig;
  heroMeta: { copy: string; cta: Cta };
  nextStepCards: HomeCardItem[];
  givingContent: GivingContent;
};

const visitSchedule = site.schedule;
const address = site.contact.address;
const mapsUrl = site.contact.mapsUrl;
const exploreMinistriesLabel = "Explore ministries";
const exploreMinistriesHref = "/ministries";
---

<HomeHeroSection heroConfig={heroConfig}>
  <div slot="meta" class="home-hero__meta">
    <div class="home-hero__meta-copy-group">
      <p class="muted home-hero__meta-copy">{heroMeta.copy}</p>
      <Button href={heroMeta.cta.href} variant="secondary">
        {heroMeta.cta.label}
      </Button>
    </div>
  </div>
</HomeHeroSection>

<main class="home-page stack" aria-label="Homepage">
  <HomeVisitSection
    schedule={visitSchedule}
    address={address}
    mapsUrl={mapsUrl}
    primaryCtaLabel={heroConfig.primaryCtaLabel}
    primaryCtaHref={heroConfig.primaryCtaHref}
    secondaryCtaLabel={exploreMinistriesLabel}
    secondaryCtaHref={exploreMinistriesHref}
  />

  <HomeCardArea
    title="Next steps"
    subtitle="Choose how you want to connect, watch, or reach out."
    cards={nextStepCards}
  />

  <EventList title="Upcoming events" />

  <LiveCalendarPreview
    title="Live calendar preview"
    description="The shared campus calendar shows the latest services, ministries, and outreach."
    embedUrl={site.portals.calendarEmbedUrl}
    compact
  />

  <section class="home-page__section home-page__media surface-section">
    <div class="home-page__media-inner">
      <p class="muted small">Prefer to preview a message before your visit?</p>
      <Button variant="tertiary" href="/media/videos">
        Watch the latest sermon
      </Button>
    </div>
  </section>

  <HomeGivingBlock content={givingContent} />
</main>

<style>
  .home-page {
    width: 100%;
    margin-top: clamp(var(--space-6), 5vw, var(--space-10));
    display: grid;
    gap: clamp(var(--space-7), 3vw, var(--space-9));
  }

  .home-card-area {
    width: 100%;
  }

  .home-page__media {
    width: 100%;
  }

  .home-page__media .home-page__media-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: 0;
  }

  @media (max-width: 640px) {
    .home-page__media-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .home-page__media-inner .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
