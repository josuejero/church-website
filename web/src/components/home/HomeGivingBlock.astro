---
import BudgetProgress from "../ui/BudgetProgress.astro";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import type { GivingContent } from "../../data/homeContent";

const { content } = Astro.props as { content: GivingContent };
---

<section class="home-giving block stack surface-section" aria-label="Giving">
  <SectionHeading title={content.title} subtitle={content.subtitle} />
  <BudgetProgress embedded />
  <p class="home-giving__copy">{content.copy}</p>
  <div class="home-giving__cta">
    <Button href={content.primaryCta.href}>{content.primaryCta.label}</Button>
    <Button variant="secondary" href={content.secondaryCta.href}>
      {content.secondaryCta.label}
    </Button>
  </div>
</section>

<style>
  .home-giving__copy {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .home-giving__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .home-giving__cta .btn {
    min-width: 180px;
  }
</style>
