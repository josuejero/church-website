---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import churchLogo from "../../assets/photos/church-logo-primary.jpg";
import { site } from "../../data/site";

const pathname = Astro.url?.pathname ?? "/";

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}

function linkAttrs(item: { href: string; external?: boolean }) {
  return item.external ? { target: "_blank", rel: "noopener noreferrer" } : {};
}

const primaryNav = site.nav;
const utilityLinks = site.utilityLinks ?? [];

const watchLive =
  site.quickActions.find((i) => i.label === "Watch Live") ??
  site.quickActions[0];
const give =
  site.quickActions.find((i) => i.label === "Give") ?? site.quickActions[1];
const otherQuick = site.quickActions.filter(
  (i) => i.label !== watchLive?.label && i.label !== give?.label,
);
const brandAriaLabel = `${site.shortName} – ${site.name}`;
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href="/" aria-label={brandAriaLabel}>
      <Image
        src={churchLogo}
        alt={`${site.name} logo`}
        widths={[36, 44, 56]}
        sizes="48px"
        loading="eager"
        decoding="async"
        class="brand__logo"
      />
      <span class="brand__title signature-text">{site.shortName}</span>
    </a>

    <nav class="nav nav--desktop" aria-label="Primary navigation">
      {
        primaryNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            {...linkAttrs(item)}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="right">
      <div class="cta cta--desktop" aria-label="Primary actions">
        {
          watchLive && (
            <Button
              href={watchLive.href}
              variant="secondary"
              size="sm"
              external={!!watchLive.external}
            >
              {watchLive.label}
            </Button>
          )
        }
        {
          give && (
            <Button
              href={give.href}
              variant="primary"
              size="sm"
              external={!!give.external}
            >
              {give.label}
            </Button>
          )
        }
      </div>

      <div class="cta cta--mobile" aria-label="Primary actions">
        {
          watchLive && (
            <Button
              href={watchLive.href}
              variant="secondary"
              size="sm"
              external={!!watchLive.external}
            >
              {watchLive.label}
            </Button>
          )
        }
        {
          give && (
            <Button
              href={give.href}
              variant="primary"
              size="sm"
              external={!!give.external}
            >
              {give.label}
            </Button>
          )
        }
      </div>

      <details class="menu" aria-label="Mobile menu">
        <summary class="menu__summary" aria-label="Open menu">
          <span class="menu__icon" aria-hidden="true">☰</span>
          <span class="menu__label">Menu</span>
        </summary>

        <div class="menu__panel">
          <nav class="menu__section" aria-label="Primary navigation">
            {
              site.nav.map((item) => (
                <a
                  class="menu__link"
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  {...linkAttrs(item)}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>

          {
            otherQuick.length > 0 && (
              <>
                <div
                  class="menu__divider"
                  role="separator"
                  aria-hidden="true"
                />

                <div class="menu__section" aria-label="Quick links">
                  <p class="menu__section-title">Quick links</p>
                  <div class="menu__quicklinks" aria-label="More quick links">
                    {otherQuick.map((item) => (
                      <a
                        class="menu__sublink"
                        href={item.href}
                        {...linkAttrs(item)}
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            )
          }

          {
            utilityLinks.length > 0 && (
              <>
                <div
                  class="menu__divider"
                  role="separator"
                  aria-hidden="true"
                />

                <div class="menu__section" aria-label="More links">
                  <p class="menu__section-title">More links</p>
                  {utilityLinks.map((item) => (
                    <a class="menu__link" href={item.href} {...linkAttrs(item)}>
                      {item.label}
                    </a>
                  ))}
                </div>
              </>
            )
          }
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector(".site-header");

  if (header instanceof HTMLElement) {
    const menu = header.querySelector("details.menu");
    const summary = menu?.querySelector("summary.menu__summary");

    if (menu instanceof HTMLDetailsElement && summary instanceof HTMLElement) {
      const desktopNavBreakpoint = window.matchMedia("(max-width: 1100px)");

      const syncMenuLabel = () => {
        const label = menu.open ? "Close menu" : "Open menu";
        summary.setAttribute("aria-label", label);
        summary.setAttribute("aria-expanded", String(menu.open));
      };

      const closeMenu = (restoreFocus = false) => {
        if (!menu.open) return;
        menu.open = false;
        if (restoreFocus) summary.focus();
      };

      syncMenuLabel();
      menu.addEventListener("toggle", syncMenuLabel);

      document.addEventListener("click", (event) => {
        if (!menu.open) return;

        const target = event.target;
        if (!(target instanceof Node)) return;

        if (target instanceof Element) {
          const link = target.closest("a");
          if (link && menu.contains(link)) {
            closeMenu();
            return;
          }
        }

        if (!menu.contains(target)) {
          closeMenu();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape" || !menu.open) return;
        event.preventDefault();
        closeMenu(true);
      });

      const handleBreakpointChange = (event: MediaQueryListEvent) => {
        if (!event.matches) closeMenu();
      };

      if (typeof desktopNavBreakpoint.addEventListener === "function") {
        desktopNavBreakpoint.addEventListener("change", handleBreakpointChange);
      } else {
        desktopNavBreakpoint.addListener(handleBreakpointChange);
      }
    }
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(
      in srgb,
      var(--color-section-surface) 92%,
      #ffffff 8%
    );
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    box-shadow: 0 14px 35px rgba(5, 6, 30, 0.12);
    backdrop-filter: saturate(180%) blur(20px);
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-3) var(--container-pad);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
  }

  .menu__section-title {
    margin: 0;
    font-size: var(--font-size-0);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .brand {
    text-decoration: none;
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .brand__logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-3);
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand__title {
    font-weight: 600;
    letter-spacing: 0.12em;
    font-size: clamp(1.2rem, 1.05rem + 0.7vw, 1.55rem);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.35rem, 0.9vw, 0.8rem);
    justify-content: center;
    flex-wrap: nowrap;
    min-width: 0;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    font-weight: 700;
    font-size: clamp(0.84rem, 0.8rem + 0.22vw, 0.95rem);
    opacity: 0.9;
    padding: 0.5rem 0.62rem;
    min-width: auto;
    justify-content: center;
    border-radius: 999px;
    white-space: nowrap;
  }

  .nav a:hover {
    background: color-mix(
      in srgb,
      var(--color-primary) 12%,
      var(--color-surface) 88%
    );
    opacity: 1;
  }

  .nav a[aria-current="page"] {
    background: color-mix(
      in srgb,
      var(--color-primary) 25%,
      var(--color-primary-soft) 75%
    );
    color: var(--color-white);
    opacity: 1;
    box-shadow: 0 8px 20px rgba(13, 8, 55, 0.25);
  }

  .cta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    justify-content: flex-end;
    min-width: 0;
  }

  .right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-2);
    min-width: 0;
    position: relative;
  }

  .cta--mobile {
    display: none;
  }

  /* Mobile menu */
  .menu {
    display: none;
  }

  .menu__summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    padding: 0.65rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-section-surface);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    min-height: var(--target-min);
    min-width: var(--target-min);
    width: 100%;
    justify-content: center;
    max-width: 200px;
  }

  .menu__summary::-webkit-details-marker {
    display: none;
  }

  .menu[open] .menu__summary {
    background: color-mix(
      in srgb,
      var(--color-primary-soft) 18%,
      var(--color-section-surface) 82%
    );
  }

  .menu__panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    right: 0;
    max-width: min(28rem, calc(100vw - 2 * var(--container-pad)));
    max-height: calc(100vh - 8rem);
    max-height: calc(100dvh - 8rem);
    background: var(--color-section-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    padding: var(--space-3);
    z-index: 60;
    box-sizing: border-box;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .menu__section {
    display: grid;
    gap: var(--space-2);
    width: 100%;
  }

  .menu__link {
    display: flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    font-weight: 700;
    padding: 0.6rem 0.7rem;
    border-radius: var(--radius-2);
  }

  .menu__link:hover {
    background: color-mix(
      in srgb,
      var(--color-primary-soft) 12%,
      var(--color-section-surface) 88%
    );
  }

  .menu__link[aria-current="page"] {
    background: color-mix(
      in srgb,
      var(--color-primary) 24%,
      var(--color-primary-soft) 76%
    );
    color: var(--color-white);
    box-shadow: 0 8px 18px rgba(13, 8, 55, 0.22);
  }

  .menu__divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-3) 0;
  }

  .menu__quicklinks {
    margin-top: var(--space-3);
    display: grid;
    gap: 0.25rem;
  }

  .menu__sublink {
    display: inline-flex;
    align-items: center;
    min-height: var(--target-min);
    text-decoration: none;
    color: var(--color-primary);
    opacity: 0.85;
    padding: 0.4rem 0.2rem;
    font-weight: 700;
  }

  .menu__sublink:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .cta--desktop {
      display: none;
    }

    .cta--mobile {
      display: flex;
    }

    .menu {
      display: block;
    }

    .nav--desktop {
      display: none;
    }

    .inner {
      grid-template-columns: auto 1fr auto;
      gap: var(--space-2);
    }
  }

  @media (max-width: 860px) {
    .inner {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto auto;
      gap: var(--space-2);
    }

    .brand {
      grid-row: 1;
    }

    .brand__title {
      white-space: nowrap;
    }

    .right {
      grid-column: 1;
      grid-row: 2;
      justify-content: space-between;
    }

    .cta--mobile {
      flex: 1;
      justify-content: flex-start;
    }

    .cta--mobile .btn {
      min-width: 0;
      padding-inline: var(--space-3);
    }

    .right {
      gap: var(--space-1);
    }
  }

  @media (max-width: 420px) {
    .brand__title {
      font-size: 1.08rem;
      letter-spacing: 0.08em;
    }

    .cta--mobile .btn {
      padding-inline: var(--space-2);
    }

    .menu__label {
      display: none;
    }

    .menu__summary {
      padding: 0.55rem 0.6rem;
    }

    .nav a {
      padding: 0.45rem 0.56rem;
    }
  }
</style>
