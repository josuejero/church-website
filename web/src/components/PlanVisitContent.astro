---
import Schedule from "./ui/Schedule.astro";
import Button from "./ui/Button.astro";
import { site } from "../data/site";
---

<div class="stack text-on-dark">
  <h1>Plan a Visit</h1>

  <Schedule title="Service Times" items={site.schedule} />

  <section class="card stack">
    <h2>Directions</h2>
    <p class="muted">
      Address:
      <a href={site.contact.mapsUrl} target="_blank" rel="noopener noreferrer">
        {site.contact.address}
      </a>
    </p>

    <ul class="muted">
      {site.visit.directions.map((direction) => (
        <li>{direction}</li>
      ))}
    </ul>
  </section>

  <section class="card stack">
    <h2>What to expect</h2>
    <p class="muted">{site.visit.languageNote}</p>
    <p class="muted">{site.visit.parkingNote}</p>
    <p class="muted">{site.visit.accessibilityNote}</p>
  </section>

  <section class="card stack">
    <h2>Submit a Connect Card</h2>
    <p class="muted">
      Share a few details before your visit so our hospitality team can welcome you, pray with you,
      and help you get settled.
    </p>
    <div class="cluster">
      <Button href="/connect/connect-card" variant="primary">Submit a Connect Card</Button>
      <Button href="/connect/contact" variant="secondary">Contact hospitality</Button>
    </div>
  </section>
</div>
