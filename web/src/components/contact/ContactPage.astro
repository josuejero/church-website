---
import Button from "../ui/Button.astro";
import ContactSection from "./ContactSection.astro";
import { buildContactSections } from "../../lib/contact-sections";

const { hasContactForm, contactFormUrl } = Astro.props as {
  hasContactForm: boolean;
  contactFormUrl?: string;
};

const sections = buildContactSections({ hasContactForm, contactFormUrl });
---

<div class="stack">
  <h1>Contact & Connect</h1>
  <p class="muted">
    The main hub for directions, service times, and topics you might need. When you’re ready, submit a
    Connect Card and our hospitality team will follow up before your visit.
  </p>

  <section class="card connect-card-teaser" aria-labelledby="connect-card-teaser-title">
    <div class="connect-card-teaser__content">
      <div>
        <p class="muted small">Stay in the loop</p>
        <h2 id="connect-card-teaser-title">Connect Card</h2>
        <p class="muted">
          Share your visit plans, prayer needs, or ministry interests and we’ll respond with arrival info,
          resources, or a next step invitation.
        </p>
      </div>
      <div class="connect-card-teaser__actions">
        <Button href="/connect/connect-card" variant="primary">
          Submit a Connect Card
        </Button>
      </div>
    </div>
  </section>

  {sections.map((section) => (
    <ContactSection section={section} key={section.id} />
  ))}
</div>

<style>
  .connect-card-teaser__content {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
  }

  .connect-card-teaser__actions {
    display: flex;
    gap: var(--space-2);
  }

  @media (max-width: 640px) {
    .connect-card-teaser__content {
      flex-direction: column;
      align-items: flex-start;
    }

    .connect-card-teaser__actions {
      width: 100%;
    }
  }
</style>
