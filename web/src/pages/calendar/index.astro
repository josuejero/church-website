---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AnnualCalendarSection from "../../components/sections/AnnualCalendarSection.astro";
import LiveCalendarPreview from "../../components/sections/LiveCalendarPreview.astro";
import { site } from "../../data/site";
import annualCalendar from "../../data/annual-calendar.json";
---

<BaseLayout title="Annual calendar" description="Seasonal events, highlights, and the Camp Meeting schedule for the year.">
  <div class="stack calendar-page">
    <section class="stack">
      <h1>Annual calendar</h1>
      <p class="muted">
        Use the live calendar to see what&apos;s happening now, while this curated highlight list helps you plan around the big milestones and seasonal gatherings.
      </p>
      <p class="muted small">
        Everything on this page pulls from the structured annual timeline, but the embed below is the single source of truth for the current campus schedule.
      </p>
    </section>

    <div class="calendar-page__grid">
      <LiveCalendarPreview
        title="Live event calendar"
        description="This public, shared calendar is the place to find the most current services, outreach, and ministry gatherings."
        embedUrl={site.portals.calendarEmbedUrl}
      />

      <AnnualCalendarSection calendarData={annualCalendar} />
    </div>
  </div>
</BaseLayout>

<style>
  .calendar-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: var(--space-6);
  }
</style>
