---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AnnualCalendarSection from "../../components/sections/AnnualCalendarSection.astro";
import annualCalendar from "../../data/annual-calendar.json";
---

<BaseLayout title="Annual calendar" description="Seasonal events, highlights, and the Camp Meeting schedule for the year.">
  <div class="stack">
    <section class="stack">
      <h1>Annual calendar</h1>
      <p class="muted">
        A quick glance at milestone dates, planning notes, and the times the campus shifts gears across the season.
      </p>
    </section>

    <AnnualCalendarSection calendarData={annualCalendar} />
  </div>
</BaseLayout>
