---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/ui/Hero.astro";
import Button from "../../../components/ui/Button.astro";
---

<BaseLayout
  title="Adventurer schedule"
  description="Adventurer schedule updates now flow through the shared church calendar."
>
  <div class="stack">
    <Hero
      title="Adventurer schedule"
      subtitle="This temporary page remains live for older links, but confirmed Adventurer and Pathfinder dates now live on the shared campus calendar."
      primaryCtaLabel="View campus calendar"
      primaryCtaHref="/calendar"
      secondaryCtaLabel="Open Pathfinders & Adventurers"
      secondaryCtaHref="/ministries/pathfinders"
    />

    <section class="card stack--tight">
      <h2>Where to find current details</h2>
      <p class="muted">
        Use the shared calendar for confirmed gatherings, special outings, and church-wide youth events.
        Use the combined club page for ministry overview, registration guidance, memo access, and contact details.
      </p>
      <div class="cluster cluster--loose">
        <Button href="/calendar" variant="primary">View campus calendar</Button>
        <Button href="/ministries/pathfinders#adventurers" variant="secondary">
          Go to Adventurer section
        </Button>
      </div>
    </section>
  </div>
</BaseLayout>
