---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeLayout from "../components/home/HomeLayout.astro";
import { site } from "../data/site";
import {
  connectedCards,
  givingContent,
  homeHeroConfig,
  homeHeroMeta,
  ministryCards,
  photoMontage,
} from "../data/homeContent";
---

<BaseLayout title={site.name} description={site.description}>
  <HomeLayout
    heroConfig={homeHeroConfig}
    heroMeta={homeHeroMeta}
    ministryCards={ministryCards}
    connectedCards={connectedCards}
    givingContent={givingContent}
    photoMontage={photoMontage}
  />
</BaseLayout>
