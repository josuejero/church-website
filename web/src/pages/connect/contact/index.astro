---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContactPage from "../../../components/contact/ContactPage.astro";
import { site } from "../../../data/site";

const hasContactForm = Boolean(site.portals.contactFormUrl && site.portals.contactFormUrl !== "TBD");
const contactFormUrl = hasContactForm ? site.portals.contactFormUrl : undefined;
---

<BaseLayout
  title="Contact & Connect"
  description={`Contact ${site.name}: address, service times, topics, and the Connect Card in one hub.`}
>
  <ContactPage hasContactForm={hasContactForm} contactFormUrl={contactFormUrl} />
</BaseLayout>
